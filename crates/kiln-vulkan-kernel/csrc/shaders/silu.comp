// SiLU (Swish) activation kernel: x * sigmoid(x)
#version 450
layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;
layout(push_constant) uniform Parameters { uint count; };
layout(binding = 0) readonly buffer XBuf { float data_x[]; };
layout(binding = 1) writeonly buffer OutBuf { float data_out[]; };
void main() {
    uint idx = gl_GlobalInvocationID.x;
    if (idx >= count) return;
    float x = data_x[idx];
    data_out[idx] = x / (1.0 + exp(-x));
}
